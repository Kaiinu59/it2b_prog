using System;
class Program
{
    static void Main()
    {
        Console.Write("Zadej slovo: ");
        string slovo = Console.ReadLine();
        Console.Write("Zadej pismeno: ");
        char pismeno = Console.ReadKey().KeyChar;

        for (int i = 0; i < slovo.Length; i++)
        {
            if (slovo[i] != pismeno)
            {
                Console.Write(slovo[i]);
            }
            else
            {
                Console.Write("*");
            }
        }
    }
}